# 推荐固定到正式版本标签，例如 misonl/cliproxyapi:v6.8.47-mf.1
CLI_PROXY_IMAGE=misonl/cliproxyapi:__VERSION__
CLI_PROXY_CONTAINER_NAME=cliproxyapi
CLI_PROXY_WORKER_CONTAINER_NAME=cliproxyapi-worker

CLI_PROXY_PUBLIC_PORT=8317
PLATFORM_POSTGRES_PUBLIC_PORT=15432

DEPLOY=
MANAGEMENT_STATIC_PATH=/workspace/static
USAGE_BACKUP_DIR=/workspace/usage-backups
TZ=Asia/Shanghai

CPA_PLATFORM_ROLE=server
CPA_PLATFORM_DATABASE_SCHEMA=controlplane
CPA_PLATFORM_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cliproxy?sslmode=disable
CPA_PLATFORM_REDIS_URL=redis://redis:6379/0
CPA_PLATFORM_NATS_URL=nats://nats:4222
CPA_PLATFORM_NATS_STREAM=CPA_EVENTS
CPA_PLATFORM_TENANT_SLUG=default
CPA_PLATFORM_TENANT_NAME=Default Tenant
CPA_PLATFORM_WORKSPACE_SLUG=default
CPA_PLATFORM_WORKSPACE_NAME=Default Workspace
CPA_MASTER_KEY=change-me-to-a-long-random-secret

PLATFORM_POSTGRES_DB=cliproxy
PLATFORM_POSTGRES_USER=postgres
PLATFORM_POSTGRES_PASSWORD=postgres
PLATFORM_POSTGRES_CONTAINER_NAME=cliproxyapi-postgres
PLATFORM_REDIS_CONTAINER_NAME=cliproxyapi-redis
PLATFORM_NATS_CONTAINER_NAME=cliproxyapi-nats
